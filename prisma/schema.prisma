generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ExtratoLog {
  id           Int      @id @default(autoincrement())
  codeSap      String
  cnpj         String
  produtor     String
  dataGeracao  String?
  usuarioEmail String
  geradoEm     DateTime @default(now())

  @@map("extrato_logs")
}
